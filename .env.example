# jobscope secrets. Copy to .env and fill in what you use. Never commit .env.

# Free AI backend (Groq recommended: fast, generous free tier).
# Get one at https://console.groq.com/keys
JOBSCOPE_AI_API_KEY=

# Gmail App Password for email summaries (NOT your normal password).
# https://myaccount.google.com/apppasswords
JOBSCOPE_SMTP_PASSWORD=

# Optional: richer enrichment. All enrichment works without these.
FINNHUB_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
