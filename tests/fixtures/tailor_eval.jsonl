{"id": "basic", "title": "Senior Security Engineer", "company": "Acme", "description": "We want python, aws, kubernetes, iam, terraform and sast experience for our platform team.", "mock_reply": "Senior security engineer with ~8 years across cloud and IAM, focused on Acme's platform security."}
