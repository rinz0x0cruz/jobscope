{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jobscope/schema/dashboard.schema.json",
  "title": "jobscope dashboard payload",
  "description": "Machine-readable mirror of render.build_data() (render.py). Single source of truth for the Python->TypeScript data contract (ARCHITECTURE.md section 9). Keep 1:1 with web/src/lib/schema.ts and tests/test_dashboard_json.py. Emitted by `jobscope dashboard --emit-json` to data/dashboard.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["generated", "total", "rows", "overview", "applications", "profile", "applied_outreach"],
  "properties": {
    "generated": {"type": "string", "description": "ISO timestamp (now_iso())."},
    "total": {"type": "integer", "description": "len(rows)."},
    "rows": {"type": "array", "items": {"$ref": "#/definitions/JobRow"}},
    "overview": {"$ref": "#/definitions/Overview"},
    "applications": {
      "type": "array",
      "description": "Empty ([]) for the public build; _application_records() otherwise.",
      "items": {"$ref": "#/definitions/Application"}
    },
    "profile": {
      "description": "Résumé-derived search profile; null for the public build, present behind the site unlock.",
      "oneOf": [{"type": "null"}, {"$ref": "#/definitions/Profile"}]
    },
    "applied_outreach": {
      "type": "array",
      "description": "Pre-computed HR contacts for active applied companies; empty ([]) for the public build, present behind the site unlock.",
      "items": {"$ref": "#/definitions/AppliedCompany"}
    }
  },
  "definitions": {
    "CompanyContact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email", "confidence", "source", "note"],
      "properties": {
        "email": {"type": "string"},
        "confidence": {"type": "string"},
        "source": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "AppliedCompany": {
      "type": "object",
      "additionalProperties": false,
      "required": ["company", "domain", "status", "applied_at", "contacts"],
      "properties": {
        "company": {"type": "string"},
        "domain": {"type": "string"},
        "status": {"type": "string"},
        "applied_at": {"type": "string"},
        "contacts": {"type": "array", "items": {"$ref": "#/definitions/CompanyContact"}}
      }
    },
    "Profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resume", "seniority", "years_experience", "search_terms", "locations", "remote", "top_skills", "name", "available"],
      "properties": {
        "resume": {"type": "string"},
        "seniority": {"type": "string"},
        "years_experience": {"type": "number"},
        "search_terms": {"type": "array", "items": {"type": "string"}},
        "locations": {"type": "array", "items": {"type": "string"}},
        "remote": {"type": "boolean"},
        "top_skills": {"type": "array", "items": {"type": "string"}},
        "name": {"type": "string"},
        "available": {"type": "array", "items": {"type": "string"}}
      }
    },
    "Tier": {"type": "string", "enum": ["Strong", "Good", "Stretch", "Skip"]},
    "JobRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "title", "company", "location", "remote", "remote_scope", "url",
        "source", "score", "tier", "base", "salary", "size", "funding",
        "country", "place", "industry", "rationale", "blocked", "posted",
        "first_seen", "status", "last_seen", "closed_at", "posted_age_days",
        "stale", "remote_mismatch", "sources", "coverage_pct", "enrich", "brief",
        "description", "contacts"
      ],
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "company": {"type": "string"},
        "location": {"type": "string"},
        "remote": {"type": "boolean"},
        "remote_scope": {"type": "string"},
        "url": {"type": "string"},
        "source": {"type": "string"},
        "score": {"type": "number"},
        "tier": {"$ref": "#/definitions/Tier"},
        "base": {"type": "string"},
        "salary": {"type": "string"},
        "size": {"type": "string"},
        "funding": {"type": "string"},
        "country": {"type": "string"},
        "place": {"type": "string"},
        "industry": {"type": ["string", "null"]},
        "rationale": {"type": "string"},
        "blocked": {"type": "boolean"},
        "posted": {"type": ["string", "null"]},
        "first_seen": {"type": "string"},
        "status": {"type": "string"},
        "last_seen": {"type": "string"},
        "closed_at": {"type": "string"},
        "posted_age_days": {"type": ["integer", "null"]},
        "stale": {"type": "boolean"},
        "remote_mismatch": {"type": "boolean"},
        "sources": {"type": "array", "items": {"type": "object", "required": ["source", "url"], "properties": {"source": {"type": "string"}, "url": {"type": "string"}}}},
        "coverage_pct": {"type": ["number", "null"]},
        "enrich": {"$ref": "#/definitions/EnrichSummary"},
        "brief": {"type": "string"},
        "description": {"type": "string", "description": "Trimmed JD snapshot (issue #30); \"\" in the public build."},
        "contacts": {"type": "array", "items": {"$ref": "#/definitions/Contact"}}
      }
    },
    "Contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {"type": ["string", "null"]},
        "title": {"type": ["string", "null"]},
        "url": {"type": ["string", "null"]}
      }
    },
    "EnrichSummary": {
      "type": "object",
      "additionalProperties": false,
      "description": "All sub-objects optional; _enrich_summary() omits empty sections.",
      "properties": {
        "stock": {"$ref": "#/definitions/StockSummary"},
        "comp": {"type": "object"},
        "reddit": {"$ref": "#/definitions/RedditSummary"},
        "news": {"type": "array", "items": {"$ref": "#/definitions/NewsItem"}},
        "glassdoor": {"type": "object"}
      }
    },
    "StockSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ticker": {"type": ["string", "null"]},
        "price": {"type": ["number", "null"]},
        "change_pct": {"type": ["number", "null"]},
        "market_cap": {"type": ["string", "null"]},
        "public": {"type": ["boolean", "null"]},
        "currency": {"type": ["string", "null"]},
        "week52_low": {"type": ["number", "null"]},
        "week52_high": {"type": ["number", "null"]},
        "week52_pos_pct": {"type": ["number", "null"]}
      }
    },
    "RedditSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sentiment": {"type": ["string", "null"]},
        "summary": {"type": ["string", "null"]},
        "count": {"type": ["integer", "null"]}
      }
    },
    "NewsItem": {
      "type": "object",
      "properties": {
        "title": {"type": ["string", "null"]},
        "link": {"type": ["string", "null"]},
        "published": {"type": ["string", "null"]},
        "source": {"type": ["string", "null"]}
      }
    },
    "Overview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["funnel", "gaps", "considered", "targets"],
      "properties": {
        "funnel": {"type": "object", "additionalProperties": {"type": "integer"}},
        "gaps": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": [{"type": "string"}, {"type": "number"}]
          }
        },
        "considered": {"type": "integer"},
        "targets": {"type": "array", "items": {"type": "string"}}
      }
    },
    "Application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id", "company", "title", "status", "applied_at", "updated",
        "source", "interview_at", "salary_offered", "offer_accepted", "timeline"
      ],
      "properties": {
        "job_id": {"type": "string"},
        "company": {"type": "string"},
        "title": {"type": "string"},
        "status": {"type": "string"},
        "applied_at": {"type": "string"},
        "updated": {"type": "string"},
        "source": {"type": "string"},
        "interview_at": {"type": "string"},
        "salary_offered": {"type": "string"},
        "offer_accepted": {"type": "string"},
        "timeline": {"type": "array", "items": {"$ref": "#/definitions/ApplicationEvent"}}
      }
    },
    "ApplicationEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "signal", "subject", "from", "summary"],
      "properties": {
        "date": {"type": "string"},
        "signal": {"type": "string"},
        "subject": {"type": "string"},
        "from": {"type": "string"},
        "summary": {"type": "string"}
      }
    }
  }
}
